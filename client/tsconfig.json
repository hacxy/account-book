{
  "extends": "@hacxy/tsconfig",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "typeRoots": ["node_modules/@types"]
  },
  "include": ["./src", "./types"],
  "compileOnSave": false
}
